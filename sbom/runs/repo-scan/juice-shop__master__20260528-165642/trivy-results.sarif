              "id": "CVE-2026-41907",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "uuid: uuid: Out-of-bounds write vulnerability impacts data integrity and confidentiality"
              },
              "fullDescription": {
                "text": "uuid is for the creation of RFC9562 (formerly RFC4122) UUIDs. Prior to 14.0.0, v3, v5, and v6 accept external output buffers but do not reject out-of-range writes (small buf or large offset). This allows silent partial writes into caller-provided buffers. This vulnerability is fixed in 14.0.0."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2026-41907",
