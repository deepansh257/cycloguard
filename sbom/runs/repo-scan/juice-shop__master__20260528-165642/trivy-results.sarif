  "runs": [
    {
      "tool": {
        "driver": {
          "fullName": "Trivy Vulnerability Scanner",
          "informationUri": "https://github.com/aquasecurity/trivy",
          "name": "Trivy",
          "rules": [
            {
              "id": "CVE-2026-3449",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "@tootallnate/once: @tootallnate/once: Denial of Service due to incorrect control flow scoping with AbortSignal"
              },
              "fullDescription": {
                "text": "Versions of the package @tootallnate/once before 3.0.1 are vulnerable to Incorrect Control Flow Scoping in promise resolving when AbortSignal option is used. The Promise remains in a permanently pending state after the signal is aborted, causing any await or .then() usage to hang indefinitely. This can cause a control-flow leak that can lead to stalled requests, blocked workers, or degraded application availability."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2026-3449",
              "help": {
                "text": "Vulnerability CVE-2026-3449\nSeverity: LOW\nPackage: @tootallnate/once\nFixed Version: 3.0.1, 2.0.1\nLink: [CVE-2026-3449](https://avd.aquasec.com/nvd/cve-2026-3449)\nVersions of the package @tootallnate/once before 3.0.1 are vulnerable to Incorrect Control Flow Scoping in promise resolving when AbortSignal option is used. The Promise remains in a permanently pending state after the signal is aborted, causing any await or .then() usage to hang indefinitely. This can cause a control-flow leak that can lead to stalled requests, blocked workers, or degraded application availability.",
                "markdown": "**Vulnerability CVE-2026-3449**\n| Severity | Package | Fixed Version | Link |\n| --- | --- | --- | --- |\n|LOW|@tootallnate/once|3.0.1, 2.0.1|[CVE-2026-3449](https://avd.aquasec.com/nvd/cve-2026-3449)|\n\nVersions of the package @tootallnate/once before 3.0.1 are vulnerable to Incorrect Control Flow Scoping in promise resolving when AbortSignal option is used. The Promise remains in a permanently pending state after the signal is aborted, causing any await or .then() usage to hang indefinitely. This can cause a control-flow leak that can lead to stalled requests, blocked workers, or degraded application availability."
              },
              "properties": {
                "cvssv3_baseScore": 3.3,
                "cvssv3_vector": "CVSS:3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:N/I:N/A:L",
                "cvssv40_baseScore": 1.9,
                "cvssv40_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:N/VI:N/VA:L/SC:N/SI:N/SA:N/E:P",
                "precision": "very-high",
                "security-severity": "3.3",
                "tags": [
                  "vulnerability",
                  "security",
                  "LOW"
                ]
              }
            },
            {
